{
    "scopeName": "source.synapse",
    "name": "Synapse",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "match": "#.*$",
                    "name": "comment.line.number-sign.synapse"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "begin": "\"",
                    "end": "\"",
                    "name": "string.quoted.double.synapse",
                    "patterns": [
                        {
                            "match": "\\\\.",
                            "name": "constant.character.escape.synapse"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
                    "name": "constant.numeric.synapse"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "match": "\\b(funcion|si|sino|mientras|retornar|lanzar|recuperar|escuchar|importar|estructura|romper|siguiente|principal|log)\\b",
                    "name": "keyword.control.synapse"
                },
                {
                    "match": "\\b(verdadero|falso)\\b",
                    "name": "constant.language.boolean.synapse"
                },
                {
                    "match": "\\b(nulo)\\b",
                    "name": "constant.language.null.synapse"
                },
                {
                    "match": "\\b(y|o|no)\\b",
                    "name": "keyword.operator.logical.synapse"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "match": "\\b(entero|decimal|texto|logico|flotante|nulo)\\b",
                    "name": "storage.type.synapse"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "match": "\\b(escribir|escribir_linea|leer_linea|abrir|leer|cerrar|crear_tensor|suma_tensor|producto_punto|relu|reserva|libera|suma|producto|texto_a_entero|texto_a_decimal|decimal_a_texto|entero_a_texto|_argv|concat|salir)\\b",
                    "name": "support.function.builtin.synapse"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "match": "(=|\\+|\\-|\\*|/|%|<|>|==|!=|<=|>=|->)",
                    "name": "keyword.operator.synapse"
                }
            ]
        }
    }
}
