#lang: es
// main.syn — Punto de entrada ejecutable del compilador Synapse (auto-hospedado)
// Recibe: main <archivo.syn>
// Flujo: leer fuente -> parsear (AST) -> generar (C)

importar compiler.generator
importar compiler.parser
importar std.io

funcion principal() -> nulo:
    si _argc() < 2:
        log("Uso: main <archivo.syn>")
        salir(1)
    ruta = _argv(1)
    log("Compilando:", ruta)
    canal = abrir("librerias/compiler/ast_nodes.syn", "r")
    lib_ast = leer(canal)
    cerrar(canal)
    canal = abrir("librerias/compiler/parser.syn", "r")
    lib_parse = leer(canal)
    cerrar(canal)
    canal = abrir("librerias/compiler/generator.syn", "r")
    lib_gen = leer(canal)
    cerrar(canal)
    canal = abrir("librerias/std/io.syn", "r")
    lib_io = leer(canal)
    cerrar(canal)
    canal = abrir("librerias/std/math.syn", "r")
    lib_math = leer(canal)
    cerrar(canal)
    canal = abrir("librerias/std/mem.syn", "r")
    lib_mem = leer(canal)
    cerrar(canal)
    canal = abrir(ruta, "r")
    fuente = leer(canal)
    cerrar(canal)
    fuente_completa = concat(concat(concat(concat(concat(concat(lib_ast, lib_parse), lib_gen), lib_io), lib_math), lib_mem), fuente)
    programa = parsear(fuente_completa)
    errores = generar(programa, ruta)
    si errores > 0:
        log("Error:", errores, "fallo(s)")
        salir(errores)
    log("OK:", ruta)
