#lang: es
// std.mem — Gestion de memoria con semantica de transferencia
// Integrante de la Biblioteca Estandar de Sinaplink OS.
//
// Uso desde Synapse:
//   importar std.mem
//   bloque = reserva(1024)
//   libera(-> bloque)

funcion reserva(tamano: int) -> tensor:
    retornar 0

funcion libera(bloque: tensor) -> nulo:
    retornar
