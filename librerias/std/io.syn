#lang: es
// std.io — Entrada/Salida estándar (consola)
// Integrante de la Biblioteca Estandar de Synapse.
//
// Uso desde Synapse:
//   importar std.io
//   escribir("hola")
//   escribir_linea("mundo")
//   entrada = leer_linea()

funcion abrir(ruta: texto, modo: texto) -> Canal:
    retornar 0

funcion leer(canal: Canal) -> texto:
    retornar ""

funcion cerrar(-> canal: Canal) -> nulo:
    retornar

funcion escribir(texto: texto) -> nulo:
    retornar

funcion escribir_linea(texto: texto) -> nulo:
    retornar

funcion leer_linea() -> texto:
    retornar ""
