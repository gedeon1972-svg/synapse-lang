#lang: es
// std.sys — Operaciones del sistema operativo via FFI
// Integrante de la Biblioteca Estandar de Synapse.
//
// Uso desde Synapse:
//   importar std.sys
//   salir(0)

importar_c "<stdlib.h>"

// Declaracion externa de la funcion exit(3) de C standard library
externo funcion exit(codigo: entero) -> nulo

// Envoltorio nativo: finaliza el programa con un codigo de salida
funcion salir(codigo: entero) -> nulo:
    exit(codigo)
