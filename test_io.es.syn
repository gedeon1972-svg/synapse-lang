#lang: es
funcion abrir(ruta: texto, modo: texto) -> Canal:
    retornar 0
funcion leer(canal: Canal) -> texto:
    retornar ""
funcion escribir(canal: Canal, contenido: texto) -> nulo:
    retornar
funcion cerrar(-> canal: Canal) -> nulo:
    retornar
funcion reserva(tamano: int) -> tensor:
    retornar 0
funcion libera(bloque: tensor) -> nulo:
    retornar
funcion principal() -> nulo:
    archivo = abrir("test_io.syn", "r")
    contenido = leer(archivo)
    log("archivo leido:")
    log(contenido)
    cerrar(->archivo)
    log("archivo cerrado")
